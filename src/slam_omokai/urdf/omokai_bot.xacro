<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="omokai_bot">

  <!-- ═══════════════════════ Properties ═══════════════════════ -->
  <xacro:property name="chassis_length"  value="0.60"/>
  <xacro:property name="chassis_width"   value="0.40"/>
  <xacro:property name="chassis_height"  value="0.18"/>
  <xacro:property name="chassis_mass"    value="10.0"/>
  <xacro:property name="chassis_z"       value="0.16"/>   <!-- base_link above ground -->

  <xacro:property name="wheel_radius"    value="0.10"/>
  <xacro:property name="wheel_width"     value="0.05"/>
  <xacro:property name="wheel_mass"      value="1.0"/>
  <xacro:property name="wheel_y"         value="0.225"/>  <!-- half track width -->

  <xacro:property name="caster_radius"   value="0.05"/>
  <xacro:property name="caster_mass"     value="0.3"/>
  <xacro:property name="caster_x"        value="0.24"/>   <!-- fore/aft from centre -->

  <xacro:property name="lidar_radius"    value="0.05"/>
  <xacro:property name="lidar_height"    value="0.06"/>
  <xacro:property name="lidar_mass"      value="0.2"/>

  <material name="body_grey"><color rgba="0.35 0.35 0.38 1.0"/></material>
  <material name="wheel_black"><color rgba="0.08 0.08 0.08 1.0"/></material>
  <material name="lidar_red"><color rgba="0.75 0.12 0.12 1.0"/></material>

  <!-- ═══════════════════════ base_footprint / base_link ═══════════════════════ -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${chassis_z}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <material name="body_grey"/>
    </visual>
    <collision>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="${chassis_mass}"/>
      <inertia
        ixx="${chassis_mass/12.0*(chassis_width*chassis_width+chassis_height*chassis_height)}"
        iyy="${chassis_mass/12.0*(chassis_length*chassis_length+chassis_height*chassis_height)}"
        izz="${chassis_mass/12.0*(chassis_length*chassis_length+chassis_width*chassis_width)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ═══════════════════ Wheels (2x drive, differential) ═══════════════════
       True diff drive: two driven wheels on the centre axle + front/rear
       caster spheres. The old 4-wheel skid-steer could not pivot — all four
       wheels scrub sideways during rotation, and above ~0.5 rad/s the
       contacts chatter and the robot just vibrates (measured 0% of commanded
       rotation at 0.8 rad/s regardless of friction settings). -->
  <xacro:macro name="wheel" params="prefix x y">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${wheel_mass/12.0*(3*wheel_radius*wheel_radius+wheel_width*wheel_width)}"
          iyy="${wheel_mass/12.0*(3*wheel_radius*wheel_radius+wheel_width*wheel_width)}"
          izz="${wheel_mass/2.0*wheel_radius*wheel_radius}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${x} ${y} ${wheel_radius - chassis_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <!-- Grippy in all directions: drive wheels must not slide laterally,
         and with casters there is no scrub during rotation to allow for. -->
    <gazebo reference="${prefix}_wheel_link">
      <mu1>1.5</mu1>
      <mu2>1.5</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:wheel prefix="left"  x="0" y="${wheel_y}"/>
  <xacro:wheel prefix="right" x="0" y="${-wheel_y}"/>

  <!-- ═══════════════════════ Casters (2x, passive) ═══════════════════════ -->
  <xacro:macro name="caster" params="prefix x">
    <link name="${prefix}_caster_link">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="${caster_mass}"/>
        <inertia
          ixx="${2.0/5.0*caster_mass*caster_radius*caster_radius}"
          iyy="${2.0/5.0*caster_mass*caster_radius*caster_radius}"
          izz="${2.0/5.0*caster_mass*caster_radius*caster_radius}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_caster_link"/>
      <origin xyz="${x} 0 ${caster_radius - chassis_z}" rpy="0 0 0"/>
    </joint>

    <!-- Nearly frictionless: the sphere slides instead of rolling, acting as
         an ideal caster without needing a swivel joint. -->
    <gazebo reference="${prefix}_caster_link">
      <mu1>0.01</mu1>
      <mu2>0.01</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:caster prefix="front" x="${caster_x}"/>
  <xacro:caster prefix="rear"  x="${-caster_x}"/>

  <!-- ═══════════════════════ 2D Lidar ═══════════════════════ -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="${lidar_radius}" length="${lidar_height}"/></geometry>
      <material name="lidar_red"/>
    </visual>
    <collision>
      <geometry><cylinder radius="${lidar_radius}" length="${lidar_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="${lidar_mass}"/>
      <inertia
        ixx="${lidar_mass/12.0*(3*lidar_radius*lidar_radius+lidar_height*lidar_height)}"
        iyy="${lidar_mass/12.0*(3*lidar_radius*lidar_radius+lidar_height*lidar_height)}"
        izz="${lidar_mass/2.0*lidar_radius*lidar_radius}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.15 0 ${chassis_height/2 + lidar_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════ Ignition Gazebo plugins ═══════════════════════ -->
  <xacro:include filename="$(find slam_omokai)/urdf/ign_plugins.xacro"/>

</robot>
